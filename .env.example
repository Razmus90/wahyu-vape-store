# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin Authentication
ADMIN_PASSWORD=admin123
JWT_SECRET=your-jwt-secret-key-change-in-production

# Midtrans Payment (optional)
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=your-midtrans-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
SANDBOX_MIDTRANS_SERVER_KEY=your-sandbox-midtrans-server-key
SANDBOX_MIDTRANS_CLIENT_KEY=your-sandbox-midtrans-client-key
NEXT_PUBLIC_SANDBOX_MIDTRANS_CLIENT_KEY=your-sandbox-midtrans-client-key

# External APIs (optional)
OPENROUTER_API_KEY=your-openrouter-api-key
OLSERA_API_KEY=your-olsera-api-key

# iPaymu Payment Gateway
IPAYMU_MODE=false
IPAYMU_SB_API_KEY=your-sandbox-api-key
IPAYMU_SB_VA=your-sandbox-va
IPAYMU_PR_API_KEY=your-production-api-key
IPAYMU_PR_VA=your-production-va

